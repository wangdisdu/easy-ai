APP_NAME=easy-ai-backend
APP_ENV=dev
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./easy_ai.db
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
SNOWFLAKE_WORKER_ID=1

# Langfuse 观测（可选，开启需同时填写 public/secret key）
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Flowise 嵌入接入（M1）
# 开启后 /flowise/* 反向代理生效，未开启返回 503
FLOWISE_ENABLED=false
FLOWISE_INTERNAL_URL=http://127.0.0.1:3001
# 必须与 Flowise 端的 EASYAI_SHARED_SECRET 完全一致
FLOWISE_SHARED_SECRET=change-me-easyai-flowise
FLOWISE_DEFAULT_WORKSPACE=
