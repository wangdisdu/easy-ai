# easy-ai backend 开发环境
#
# 生产环境的值由 deploy/docker-compose.yml 通过 deploy/.env 注入,不走这里。
# 本地开发: cp .env.example .env 然后按需修改。
#
# DATABASE_URL 指向 compose 里的 postgres(默认 127.0.0.1:18032)。
# 如果你想让本地 backend 连 compose 的 pg,请先 `cd deploy && ./deploy.sh up postgres`,
# 再 `make py-dev && uv run python app/run.py`。

APP_ENV=dev
LOG_LEVEL=DEBUG

DATABASE_URL=postgresql+psycopg://postgres:314d6d777a67e266b52e6c88aa6c8454175e6cb422ee5d4d@127.0.0.1:18032/easyai

JWT_SECRET=dev-only-jwt-secret-not-for-prod
JWT_ALGORITHM=HS256
SNOWFLAKE_WORKER_ID=1

# Flowise 嵌入(本地开发一般不开,走 compose 里的 flowise)
FLOWISE_ENABLED=false
FLOWISE_INTERNAL_URL=http://127.0.0.1:3001
FLOWISE_SHARED_SECRET=dev-only-flowise-shared-secret

# Langfuse 观测(可选)
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://127.0.0.1:18030
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
