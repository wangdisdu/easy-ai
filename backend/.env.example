# easy-ai backend 开发环境
#
# 生产环境的值由 deploy/docker-compose.yml 通过 deploy/.env 注入,不走这里。
# 本地开发: cp .env.example .env 然后按需修改。
#
# DATABASE_URL 指向 compose 里的 postgres(默认 127.0.0.1:18032)。
# 如果你想让本地 backend 连 compose 的 pg,请先 `cd deploy && ./deploy.sh up postgres`,
# 再 `make py-dev && uv run python app/run.py`。

APP_ENV=dev
LOG_LEVEL=DEBUG

DATABASE_URL=postgresql+psycopg://postgres:314d6d777a67e266b52e6c88aa6c8454175e6cb422ee5d4d@127.0.0.1:18032/easyai

JWT_SECRET=dev-only-jwt-secret-not-for-prod
JWT_ALGORITHM=HS256
SNOWFLAKE_WORKER_ID=1

# Checkpoint 后台清理（多 worker 时用 pg advisory lock 互斥，只一个 worker 实跑）
# PURGE_ENABLED=false 可彻底关掉定时任务（HTTP /admin/purge 端点不受影响）
PURGE_ENABLED=true
PURGE_INTERVAL_SECONDS=86400
PURGE_TTL_DAYS=30

# 单次 MCP 工具调用最长等待秒数；超过强制切断（asyncio.timeout 真取消子任务）
MCP_TOOL_TIMEOUT_SECONDS=300

# Flowise 嵌入(本地开发一般不开,走 compose 里的 flowise)
FLOWISE_ENABLED=true
FLOWISE_INTERNAL_URL=http://127.0.0.1:3001
FLOWISE_SHARED_SECRET=dev-only-flowise-shared-secret

# Langfuse 观测(可选)
LANGFUSE_ENABLED=true
LANGFUSE_HOST=http://127.0.0.1:18030
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# RAGFlow 知识库引擎(本地 backend → host:18040 → 容器 9380)
# SHARED_SECRET 必须与 deploy/.env 的 RAGFLOW_SHARED_SECRET 一致(trusted-header 鉴权)
RAGFLOW_ENABLED=true
RAGFLOW_BASE_URL=http://127.0.0.1:18040
RAGFLOW_SHARED_SECRET=4f7c2e9d6a5b3c1e8f0a7b6d5e4c3b2a1d9e8f7c6b5a4d3e
RAGFLOW_TIMEOUT_SEC=30

# OpenSandbox 沙盒后端(本地 backend → compose 暴露的宿主端口 18050)
# server 由 `cd deploy && docker compose -p easy-ai --profile sandbox up -d` 启动
SANDBOX_ENABLED=true
SANDBOX_SERVER_URL=http://127.0.0.1:18050
# 本地 server 未设 api_key(SANDBOX_INSECURE=YES)时留空
SANDBOX_API_KEY=
