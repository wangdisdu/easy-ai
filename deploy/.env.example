# ============================================================
# easy-ai 全栈部署环境变量(模板)
#
# 使用方式:
#   cp .env.example .env && ./deploy.sh up
#
# 本模板采用"可直接运行的默认值"策略,拷贝后无需改动即可启动。
# 生产环境请用下面的命令重新生成密钥后再替换:
#   for i in $(seq 8); do openssl rand -hex 24; done
#   openssl rand -hex 32   # 用于 ENCRYPTION_KEY
# ============================================================

# ---- 对外暴露的端口(188xx 段,其它组件全部绑定 127.0.0.1) ----
EASYAI_HTTP_PORT=18080
LANGFUSE_WEB_PORT=18030
RAGFLOW_WEB_PORT=18044

LOG_LEVEL=INFO

# ============================================================
# easy-ai 自研
# ============================================================
JWT_SECRET=14b7e03bc611e2c7442c44e942a29dbe3d029dd549a4fde7
SNOWFLAKE_WORKER_ID=1

# Flowise 与 easy-ai 之间的 HMAC 共享密钥(两端必须一致,由 compose 自动注入)
FLOWISE_SHARED_SECRET=42cafe9e5570706c7e17c4e2e7bb4bc9de5cd00a3864bf21

# ============================================================
# Langfuse 接入
# ============================================================
# 首次启动会按下面的 LANGFUSE_INIT_* 值自动创建 org / project / admin 账号,
# 并用指定的 PROJECT_PUBLIC_KEY / PROJECT_SECRET_KEY 作为 project 的 API key。
# easy-ai-backend 通过 compose 直接引用同一对 key 接入 langfuse,无需手动拷贝。
# 登录 UI: http://localhost:${LANGFUSE_WEB_PORT} 用 LANGFUSE_INIT_USER_EMAIL + PASSWORD
LANGFUSE_ENABLED=true

# Langfuse 自身密钥(所有 langfuse-web/worker 共用)
NEXTAUTH_SECRET=7fcc012704d38dd60a4bdb86202abb8daf73aeef679afa2a
SALT=20728fc0f1388f8c7146ae3a45dfae9b50fb1b57b2289fa4
# 必须正好 64 个 hex 字符:  openssl rand -hex 32
ENCRYPTION_KEY=ae30d340ef53b027e9359daea957faebe8832713c4a7ee47939e58313a86be0e
TELEMETRY_ENABLED=false
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=true

# Langfuse 首次启动自动初始化
LANGFUSE_INIT_ORG_ID=easyai-org
LANGFUSE_INIT_ORG_NAME=easy-ai
LANGFUSE_INIT_PROJECT_ID=easyai-project
LANGFUSE_INIT_PROJECT_NAME=easy-ai
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-cf86470b-528d-49dd-b261-613ad3adbca3
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-16804ab6-ad24-4404-b58b-f084724ebf75
LANGFUSE_INIT_USER_EMAIL=admin@easyai.com
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=admin@123

# ============================================================
# 基础设施(内网 127.0.0.1 专用,不对外暴露)
# ============================================================

# ---- Postgres ---
# 固定到 15: postgres 18 改了数据目录布局,和 langfuse 挂载点 /var/lib/postgresql/data 不兼容
# langfuse 和 easy-ai 共用同一个 pg 实例 + 同一个超级用户,
# 应用库 langfuse / easyai 由 postgres-init/10-create-databases.sh 首次启动时建好
POSTGRES_VERSION=15
POSTGRES_USER=postgres
POSTGRES_PASSWORD=314d6d777a67e266b52e6c88aa6c8454175e6cb422ee5d4d

# ---- Clickhouse ----
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=9ff8d1076c60c936de46c1b3dbd6658771a769e009b4a67d
CLICKHOUSE_DB=default

# ---- Redis ----
REDIS_AUTH=e568ae7c9d8583410d25094b9b84de7fdc26940214130904

# ---- MinIO(对象存储,langfuse 事件/媒体/导出统一写同一个 bucket) ----
# MINIO_ROOT_PASSWORD 至少 8 个字符
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=KZ3YZEM0y11ISFzMNVIF
LANGFUSE_S3_EVENT_UPLOAD_BUCKET=langfuse
LANGFUSE_S3_EVENT_UPLOAD_REGION=auto

# ============================================================
# RAGFlow(知识库底层引擎)
# ============================================================
# RAGFlow 走自有 fork (ragflow/ submodule, v0.25.2 分支),
# 通过 EASYAI trusted-header 鉴权: easy-ai-backend 与 ragflow 容器
# 共用 RAGFLOW_SHARED_SECRET, 每次请求带 HMAC 签名头, RAGFlow 自动
# 绑定到内置默认管理员 easyai@system.local (启动时 easyai_bootstrap 创建)。
# 详见 docs/knowledge-rag-integration-design.md §3。
RAGFLOW_ENABLED=true
RAGFLOW_TIMEOUT_SEC=30
# 国内首次 build 时设为 1, 自动改用阿里云 pypi 镜加速 uv sync
RAGFLOW_NEED_MIRROR=0

# easyai trusted-header: backend 与 ragflow 两侧共用,必须改成强随机值
#   openssl rand -hex 24
RAGFLOW_SHARED_SECRET=4f7c2e9d6a5b3c1e8f0a7b6d5e4c3b2a1d9e8f7c6b5a4d3e
EASYAI_BOOTSTRAP_EMAIL=admin@easyai.com
EASYAI_BOOTSTRAP_NICKNAME=admin
# 默认与 easy-ai / Langfuse 统一为 admin@123,方便排障直访;留空则首次启动随机生成
EASYAI_BOOTSTRAP_PASSWORD=admin@123

# RAGFlow 专用 MySQL 与 Elasticsearch 密钥(生产请用 openssl rand 重新生成)
RAGFLOW_MYSQL_PASSWORD=c1f0a0d0c0b0a09080706050403020100f0e0d0c0b0a09080
RAGFLOW_ES_PASSWORD=8d7e6f5a4b3c2d1e0f9a8b7c6d5e4f3a2b1c0d9e8f7a6b5c
# Elasticsearch JVM 内存上限,生产环境根据机器规格调整
RAGFLOW_ES_MEM_LIMIT=4g

# ── OpenSandbox 沙盒后端 ──────────────────────────────────────────
# 默认启用; deploy.sh 自动加 --profile sandbox 拉起 server + 本地构建桌面镜像。
# 关闭设 SANDBOX_ENABLED=false。
SANDBOX_ENABLED=true
# backend 容器内走 compose service 名;改宿主直连用 http://127.0.0.1:18050
SANDBOX_SERVER_URL=http://opensandbox-server:8090
SANDBOX_SERVER_PORT=18050
# 生产强烈建议设强密钥(随机 32+ 字符):server 启用鉴权 + backend SDK 自动带上。
# 留空 = 本地不鉴权(配合下方 SANDBOX_INSECURE=YES);只允许本机/受信网络访问。
SANDBOX_API_KEY=
# 仅在 SANDBOX_API_KEY 为空时生效:YES = 显式允许 server 以不鉴权模式跑。
# 设置了 api_key 后此值被忽略。
SANDBOX_INSECURE=YES
